# Database
# Staging PostgreSQL connection string from Railway or Supabase.
STAGING_DATABASE_URL=YOUR_STAGING_DATABASE_URL_HERE
# Production PostgreSQL connection string from Railway or Supabase.
PROD_DATABASE_URL=YOUR_PROD_DATABASE_URL_HERE

# Redis
# Staging Redis connection string from Railway or Upstash.
STAGING_REDIS_URL=YOUR_STAGING_REDIS_URL_HERE
# Production Redis connection string from Railway or Upstash.
PROD_REDIS_URL=YOUR_PROD_REDIS_URL_HERE

# Auth
# JWT Secret — generate with: openssl rand -base64 64
# Must be at least 32 characters. Never commit the real value.
JWT_SECRET=YOUR_VERY_LONG_RANDOM_SECRET_HERE
# Staging Supabase JWT secret used only for Supabase token verification.
STAGING_JWT_SECRET=YOUR_STAGING_JWT_SECRET_HERE
# Production Supabase JWT secret used only for Supabase token verification.
PROD_JWT_SECRET=YOUR_PROD_JWT_SECRET_HERE

# Supabase
# Staging Supabase project URL.
STAGING_SUPABASE_URL=YOUR_STAGING_SUPABASE_URL_HERE
# Staging Supabase anon key for public client operations.
STAGING_SUPABASE_ANON_KEY=YOUR_STAGING_SUPABASE_ANON_KEY_HERE
# Staging Supabase service role key for backend admin operations.
STAGING_SUPABASE_SERVICE_ROLE_KEY=YOUR_STAGING_SUPABASE_SERVICE_ROLE_KEY_HERE
# Production Supabase project URL.
PROD_SUPABASE_URL=YOUR_PROD_SUPABASE_URL_HERE
# Production Supabase anon key for public client operations.
PROD_SUPABASE_ANON_KEY=YOUR_PROD_SUPABASE_ANON_KEY_HERE
# Production Supabase service role key for backend admin operations.
PROD_SUPABASE_SERVICE_ROLE_KEY=YOUR_PROD_SUPABASE_SERVICE_ROLE_KEY_HERE

# Razorpay
# Staging Razorpay test key ID.
STAGING_RAZORPAY_KEY_ID=YOUR_STAGING_RAZORPAY_TEST_KEY_ID_HERE
# Staging Razorpay test key secret.
STAGING_RAZORPAY_SECRET=YOUR_STAGING_RAZORPAY_TEST_SECRET_HERE
# Staging Razorpay webhook secret.
STAGING_RAZORPAY_WEBHOOK_SECRET=YOUR_STAGING_RAZORPAY_WEBHOOK_SECRET_HERE
# Staging RazorpayX account number for payouts.
STAGING_RAZORPAY_ACCOUNT_NUMBER=YOUR_STAGING_RAZORPAY_ACCOUNT_NUMBER_HERE
# Production Razorpay live key ID.
PROD_RAZORPAY_KEY_ID=YOUR_PROD_RAZORPAY_LIVE_KEY_ID_HERE
# Production Razorpay live key secret.
PROD_RAZORPAY_SECRET=YOUR_PROD_RAZORPAY_LIVE_SECRET_HERE
# Production Razorpay webhook secret.
PROD_RAZORPAY_WEBHOOK_SECRET=YOUR_PROD_RAZORPAY_WEBHOOK_SECRET_HERE
# Production RazorpayX account number for payouts.
PROD_RAZORPAY_ACCOUNT_NUMBER=YOUR_PROD_RAZORPAY_ACCOUNT_NUMBER_HERE

# CORS and WebSocket origins
# Comma-separated list of frontend URLs allowed to call the backend and connect via WebSocket.
# Example: https://your-brand-dashboard.vercel.app,https://your-admin-dashboard.vercel.app
STAGING_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
PROD_ALLOWED_ORIGINS=YOUR_BRAND_DASHBOARD_URL,YOUR_ADMIN_DASHBOARD_URL

# App
# Spring profile used by the backend when running locally.
SPRING_PROFILES_ACTIVE=staging
# Port used by the backend when running locally.
SERVER_PORT=8080
# Public production backend URL used by health checks and dashboards.
PROD_API_URL=YOUR_PROD_API_URL_HERE
