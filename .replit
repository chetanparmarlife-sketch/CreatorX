modules = ["nodejs-20", "java-graalvm22.3", "web", "bash"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-25_05"
packages = ["unzip"]

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd landing-page && npm ci && npm run build"]
run = ["bash", "-c", "cd landing-page && npm start -- -p 5000"]
publicDir = "landing-page/out"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 18260
externalPort = 3003
exposeLocalhost = true

[[ports]]
localPort = 18565
externalPort = 4200
exposeLocalhost = true

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Brand Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Landing Page"

[[workflows.workflow]]
name = "Brand Dashboard"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd brand-dashboard && npm run dev"
waitForPort = 3001

[[workflows.workflow]]
name = "Admin Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd admin-dashboard && npm run dev"
waitForPort = 3002

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Landing Page"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd landing-page && npm run dev -- -p 5000 -H 0.0.0.0"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
integrations = ["javascript_database:1.0.0"]
expertMode = true
