modules = ["nodejs-20", "java-graalvm22.3", "web", "bash"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-25_05"
packages = ["unzip"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 3003
externalPort = 3003

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Brand Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Landing Page"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo App"

[[workflows.workflow]]
name = "Brand Dashboard"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd brand-dashboard && npm run dev"
waitForPort = 3001

[[workflows.workflow]]
name = "Admin Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd admin-dashboard && npm run dev"
waitForPort = 3002

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Landing Page"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd landing-page && npm run dev -- -p 3003 -H 0.0.0.0"
waitForPort = 3003

[[workflows.workflow]]
name = "Expo App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx expo start --web --port 5000 --host lan"
waitForPort = 5000

[agent]
integrations = ["javascript_database:1.0.0"]
expertMode = true
