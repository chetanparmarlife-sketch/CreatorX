{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && ./gradlew build -x test"
  },
  "deploy": {
    "startCommand": "java -jar -Dspring.profiles.active=staging backend/creatorx-api/build/libs/creatorx-api-1.0.0.jar",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
