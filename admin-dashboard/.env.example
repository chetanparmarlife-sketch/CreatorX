# Admin Dashboard - Vercel Environment Variables
# Copy these to Vercel Dashboard > Settings > Environment Variables

# ===== API Backend =====
# Use either NEXT_PUBLIC_API_URL or NEXT_PUBLIC_API_BASE_URL (both supported)
NEXT_PUBLIC_API_URL=https://creatorx-production.up.railway.app/api/v1
NEXT_PUBLIC_API_BASE_URL=https://creatorx-production.up.railway.app/api/v1

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===== App Configuration =====
NEXT_PUBLIC_APP_URL=https://admin-creatorx.vercel.app
NEXT_PUBLIC_ENV=staging

# ===== Optional Analytics =====
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
