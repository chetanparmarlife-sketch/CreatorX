# Backend API URL used by browser code.
NEXT_PUBLIC_API_URL=YOUR_API_URL_HERE

# Backend API base URL used by the existing API client.
NEXT_PUBLIC_API_BASE_URL=YOUR_API_BASE_URL_HERE

# WebSocket URL used for live messages and real-time updates.
NEXT_PUBLIC_WS_URL=YOUR_WEBSOCKET_URL_HERE

# Supabase project URL used by the dashboard.
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL_HERE

# Supabase anon key used by browser-side Supabase calls.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Razorpay public key ID used by checkout UI.
NEXT_PUBLIC_RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID_HERE

# Brand dashboard URL used for cross-dashboard navigation.
NEXT_PUBLIC_BRAND_DASHBOARD_URL=YOUR_BRAND_DASHBOARD_URL_HERE

# Optional analytics endpoint used by brand event tracking.
NEXT_PUBLIC_BRAND_ANALYTICS_ENDPOINT=YOUR_BRAND_ANALYTICS_ENDPOINT_HERE
