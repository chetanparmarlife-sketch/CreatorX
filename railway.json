{
  "service": "creatorx-backend-prod",
  "build": {
    "command": "cd backend && ./gradlew build -x test"
  },
  "deploy": {
    "startCommand": "java -jar -Dspring.profiles.active=production backend/creatorx-api/build/libs/creatorx-api.jar",
    "healthcheckPath": "/actuator/health",
    "restartPolicyType": "ON_FAILURE"
  },
  "environment": "production"
}
