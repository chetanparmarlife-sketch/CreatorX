{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "lib": ["ES2020", "DOM"],
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "types": ["react-native"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
