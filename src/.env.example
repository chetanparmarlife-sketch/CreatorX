# Environment name used by the Expo app.
EXPO_PUBLIC_ENV=staging

# Backend API URL requested for the mobile app.
EXPO_PUBLIC_API_URL=YOUR_API_URL_HERE

# Backend API base URL used by the existing mobile API client.
EXPO_PUBLIC_API_BASE_URL=YOUR_API_BASE_URL_HERE

# Alternate backend URL supported by the existing mobile config.
EXPO_PUBLIC_BACKEND_URL=YOUR_BACKEND_URL_HERE

# WebSocket URL used for mobile live messages.
EXPO_PUBLIC_WS_URL=YOUR_WEBSOCKET_URL_HERE

# Supabase project URL used by the mobile app.
EXPO_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL_HERE

# Supabase anon key used by mobile Supabase calls.
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
